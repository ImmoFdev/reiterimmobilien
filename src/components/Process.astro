---
const steps = [
  { number: '1', title: 'Erstgespräch', text: 'Wir lernen Sie und Ihre Immobilie kennen. Kostenlos und unverbindlich.' },
  { number: '2', title: 'Bewertung', text: 'Sie erhalten eine fundierte Marktpreiseinschätzung für Ihre Region.' },
  { number: '3', title: 'Vermarktung', text: 'Professionelle Fotos, Homestaging und Exposé. Ihre Immobilie im besten Licht.' },
  { number: '4', title: 'Verkauf', text: 'Wir verhandeln für Sie und begleiten Sie bis zum Notartermin.' },
];
---
<section class="process section-padding" style="background: var(--light);">
  <div class="container">
    <p class="section-label">So funktioniert's</p>
    <h2 class="section-headline">In 4 Schritten zum <em>erfolgreichen</em> Verkauf</h2>
    <div class="process-grid">
      {steps.map((step) => (
        <div class="process-step">
          <div class="process-number">{step.number}</div>
          <h3 class="process-title">{step.title}</h3>
          <p class="process-text">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2.5rem;
    text-align: center;
  }
  .process-number {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--dark);
    color: var(--light);
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .process-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.35rem; }
  .process-text { font-size: 0.9rem; font-weight: 300; color: var(--text-secondary); }
  @media (min-width: 768px) {
    .process-grid { grid-template-columns: repeat(4, 1fr); }
    .process-number {
      width: 50px;
      height: 50px;
      font-size: 1.25rem;
    }
  }
</style>
