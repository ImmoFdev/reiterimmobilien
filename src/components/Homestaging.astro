---
const rooms = [
  {
    name: 'Wohnzimmer',
    before: '/images/homestaging/vorher-wohnzimmer.png',
    after: '/images/homestaging/nachher-wohnzimmer.png',
  },
  {
    name: 'Schlafzimmer',
    before: '/images/homestaging/vorher-schlafzimmer.png',
    after: '/images/homestaging/nachher-schlafzimmer.png',
  },
];
---
<section class="homestaging section-padding" style="background: var(--grey);">
  <div class="container">
    <p class="section-label">Kostenlos für Sie</p>
    <h2 class="section-headline">Homestaging: Bis zu 15% mehr Verkaufspreis</h2>
    <p class="section-subtext">Wir inszenieren Ihre Räume professionell. Käufer sehen nicht leere Zimmer, sondern ihr neues Zuhause. Optional und komplett kostenlos.</p>

    <div class="homestaging-rooms">
      {rooms.map((room) => (
        <article class="homestaging-room">
          <h3 class="homestaging-room-title">{room.name}</h3>
          <div class="homestaging-pair">
            <figure class="homestaging-shot">
              <img src={room.before} alt={`${room.name} vor Homestaging`} loading="lazy" decoding="async" />
              <figcaption class="homestaging-shot-label homestaging-shot-label--before">Vorher</figcaption>
            </figure>
            <figure class="homestaging-shot">
              <img src={room.after} alt={`${room.name} nach Homestaging`} loading="lazy" decoding="async" />
              <figcaption class="homestaging-shot-label homestaging-shot-label--after">Nachher</figcaption>
            </figure>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .homestaging-rooms {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2.5rem;
    max-width: 920px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 900px) {
    .homestaging-rooms {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  .homestaging-room-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--dark);
    letter-spacing: 0.02em;
    margin-bottom: 0.65rem;
    text-align: center;
  }

  .homestaging-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  @media (min-width: 500px) {
    .homestaging-pair {
      grid-template-columns: 1fr 1fr;
    }
  }

  .homestaging-shot {
    position: relative;
    margin: 0;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--accent-pri);
  }

  .homestaging-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .homestaging-shot-label {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.3rem 0.7rem;
    border-radius: 30px;
  }

  .homestaging-shot-label--before {
    background: rgba(250, 250, 250, 0.92);
    color: var(--accent-sec);
    backdrop-filter: blur(4px);
  }

  .homestaging-shot-label--after {
    background: var(--dark);
    color: var(--light);
  }

</style>
