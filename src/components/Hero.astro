---
// src/components/Hero.astro
---
<section class="hero">
  <div class="hero-media">
    <img
      src="/images/referenzen/einfamilienhaus-welkers.jpg"
      alt="Einfamilienhaus in Welkers - durch Reiter Immobilien in 7 Tagen verkauft"
      class="hero-media-img"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <span class="hero-media-badge">Verkauft in 7 Tagen</span>
    <div class="hero-media-caption">
      <span class="hero-media-caption-label">Aktuelle Referenz</span>
      <span class="hero-media-caption-title">Einfamilienhaus in Welkers</span>
    </div>
  </div>
  <div class="hero-content">
    <div class="hero-content-inner">
      <p class="hero-subline">Reiter Immobilien &middot; Fulda &amp; Umgebung</p>
      <h1 class="hero-headline">Mit uns <em>erfolgreich</em> verkaufen</h1>
      <p class="hero-subtext">Wir betreuen Ihren Immobilienverkauf in Fulda und Umgebung von A bis Z und erzielen für Sie den besten Preis.</p>

      <div class="hero-trust">
        <div class="hero-trust-item">
          <span class="hero-trust-value">4,8 &#9733;</span>
          <span class="hero-trust-label">
            <img src="/images/google-logo.svg" alt="Google" width="14" height="14" class="google-logo" />
            Google
          </span>
        </div>
        <div class="hero-trust-item">
          <span class="hero-trust-value">30+</span>
          <span class="hero-trust-label">Jahre Erfahrung</span>
        </div>
        <div class="hero-trust-item">
          <span class="hero-trust-value">100%</span>
          <span class="hero-trust-label">Persönlich</span>
        </div>
      </div>

      <a href="/formular" class="btn-primary">Verkauf besprechen &rarr;</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
  }

  .hero-media {
    position: relative;
    background: var(--accent-pri);
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero-media {
      aspect-ratio: auto;
      min-height: 80vh;
    }
  }

  .hero-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .hero-media-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--dark);
    color: var(--light);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.45rem 0.9rem;
    border-radius: 30px;
  }

  @media (min-width: 768px) {
    .hero-media-badge {
      top: 1.5rem;
      left: 1.5rem;
      font-size: 0.75rem;
      padding: 0.5rem 1rem;
    }
  }

  .hero-media-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 2rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: var(--light);
    background: linear-gradient(to top, rgba(42,39,36,0.72) 0%, rgba(42,39,36,0) 100%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .hero-media-caption {
      padding: 3rem 1.5rem 1.5rem;
    }
  }

  .hero-media-caption-label {
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.85;
  }

  .hero-media-caption-title {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .hero-content {
    background: var(--light);
    display: flex;
    align-items: center;
    padding: 2rem 1.25rem;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: 3rem;
      justify-content: center;
    }
  }

  .hero-content-inner {
    max-width: 480px;
  }

  .hero-subline {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-sec);
    margin-bottom: 1.25rem;
  }

  .hero-headline {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--dark);
    margin-bottom: 1rem;
  }

  .hero-headline em {
    font-family: 'Dancing Script', cursive;
    font-style: normal;
    font-weight: 700;
    font-size: 1.3em;
  }

  .hero-subtext {
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--accent-sec);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .hero-trust {
    display: flex;
    gap: 0;
    margin-bottom: 2rem;
  }

  .hero-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    padding: 1rem 0.5rem;
    border-right: 1px solid var(--accent-pri);
  }

  .hero-trust-item:last-child {
    border-right: none;
  }

  .hero-trust-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dark);
  }

  .hero-trust-label {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--accent-sec);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .google-logo {
    flex-shrink: 0;
    vertical-align: middle;
  }

  @media (max-width: 767px) {
    .hero-trust-value {
      font-size: 1rem;
    }
    .hero-trust-label {
      font-size: 0.7rem;
    }
  }

  .btn-primary {
    display: inline-block;
  }

  @media (max-width: 767px) {
    .btn-primary {
      display: block;
      width: 100%;
      text-align: center;
    }
  }
</style>
