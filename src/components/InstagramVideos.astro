---
// src/components/InstagramVideos.astro
---
<section class="instagram section-padding" style="background: var(--grey);">
  <div class="container">
    <p class="section-label">Einblicke</p>
    <h2 class="section-headline">Sehen Sie selbst, wie wir arbeiten</h2>
    <p class="section-subtext">Verena Reiter zeigt auf Instagram, wie ein Verkauf bei uns abläuft. Persönlich und transparent.</p>

    <div class="insta-content">
      <div class="insta-video">
        <div class="insta-placeholder">
          <img src="/images/play-button.svg" alt="" width="48" height="48" />
          <span>So läuft ein Erstgespräch ab</span>
        </div>
      </div>

      <div class="insta-nudge">
        <p class="insta-nudge-text">Mehr Einblicke auf Instagram</p>
        <p class="insta-nudge-hint">Vereinbaren Sie zuerst Ihr Erstgespräch, dann stöbern Sie in Ruhe auf unserem Profil.</p>
        <div class="insta-nudge-actions">
          <a href="/formular" class="btn-primary">Verkauf besprechen &rarr;</a>
          <a href="https://www.instagram.com/reiterimmobilien/" target="_blank" rel="noopener noreferrer" class="btn-secondary">Trotzdem zu Instagram &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .insta-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    align-items: center;
  }

  .insta-video {
    max-width: 280px;
    margin: 0 auto;
  }

  .insta-placeholder {
    width: 100%;
    aspect-ratio: 9/16;
    border: 2px dashed var(--accent-pri);
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border-radius: 4px;
  }

  .insta-placeholder span {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent-sec);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .insta-nudge {
    text-align: center;
  }

  .insta-nudge-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }

  .insta-nudge-hint {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--accent-sec);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .insta-nudge-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .insta-nudge-actions .btn-secondary {
    font-size: 0.8rem;
    padding: 0.5rem 1.25rem;
    opacity: 0.7;
  }

  .insta-nudge-actions .btn-secondary:hover {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .insta-content {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .insta-video {
      max-width: 260px;
      margin: 0 auto;
    }

    .insta-nudge {
      text-align: left;
    }

    .insta-nudge-actions {
      align-items: flex-start;
    }
  }
</style>
