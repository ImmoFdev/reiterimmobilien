---
const references = [
  {
    image: '/images/referenzen/einfamilienhaus-welkers.jpg',
    title: 'Einfamilienhaus in Welkers',
    info: 'Innerhalb 2 Wochen verkauft',
    highlight: true,
  },
  {
    image: '/images/referenzen/bungalow-petersberg.jpg',
    title: 'Bungalow in Petersberg',
    info: 'Verkauft in 4 Wochen',
  },
  {
    image: '/images/referenzen/dhh-petersberg-steinau.jpg',
    title: 'Doppelhaushälfte in Petersberg',
    info: 'Verkauft in 9 Wochen',
  },
  {
    image: '/images/referenzen/11-parteienhaus-petersberg.jpg',
    title: '11-Parteienhaus in Petersberg',
    info: 'Verkauft in 12 Wochen',
  },
  {
    image: '/images/referenzen/3-parteienhaus-hosenfeld.jpg',
    title: 'Drei-Parteienhaus in Hosenfeld',
    info: 'Verkauft nach 4 Monaten',
  },
];
---
<section class="references section-padding" style="background: var(--light);">
  <div class="container">
    <p class="section-label">Ergebnisse</p>
    <h2 class="section-headline">Erfolgreich <em>verkauft</em> in Ihrer Region</h2>
    <p class="section-subtext">Jedes Objekt erzählt eine eigene Geschichte. Hier eine Auswahl aktueller Verkäufe aus Fulda und Umgebung.</p>
  </div>

  <div class="carousel-wrap">
    <div class="carousel" role="region" aria-label="Referenzobjekte">
      {references.map((ref) => (
        <article class="ref-card">
          <div class="ref-image">
            <img src={ref.image} alt={ref.title} loading="lazy" decoding="async" />
            {ref.highlight && <span class="ref-badge">Schnellverkauf</span>}
          </div>
          <div class="ref-info">
            <h3 class="ref-title">{ref.title}</h3>
            <p class="ref-detail">{ref.info}</p>
          </div>
        </article>
      ))}
      <div class="carousel-edge" aria-hidden="true"></div>
    </div>
    <p class="carousel-hint" aria-hidden="true">← zum Durchstöbern wischen →</p>
  </div>
</section>

<style>
  .carousel-wrap {
    margin-top: 2.5rem;
    position: relative;
  }

  .carousel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding-left: 1.25rem;
    padding: 0.5rem 1.25rem 1.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--accent-pri) transparent;
  }

  .carousel::-webkit-scrollbar {
    height: 6px;
  }
  .carousel::-webkit-scrollbar-track {
    background: transparent;
  }
  .carousel::-webkit-scrollbar-thumb {
    background: var(--accent-pri);
  }

  .ref-card {
    flex: 0 0 auto;
    width: 280px;
    scroll-snap-align: start;
    background: var(--light);
    border: 1px solid var(--accent-pri);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ref-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px -16px rgba(42, 39, 36, 0.25);
  }

  .ref-image {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--grey);
  }

  .ref-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .ref-card:hover .ref-image img {
    transform: scale(1.04);
  }

  .ref-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--dark);
    color: var(--light);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.4rem 0.75rem;
    border-radius: 30px;
  }

  .ref-info {
    padding: 1.1rem 1.1rem 1.25rem;
  }

  .ref-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }

  .ref-detail {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--accent-sec);
  }

  .carousel-edge {
    flex: 0 0 1.25rem;
  }

  .carousel-hint {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--accent-sec);
    letter-spacing: 0.1em;
    margin-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .carousel {
      gap: 1.5rem;
      scroll-padding-left: 1.5rem;
      padding: 0.5rem 1.5rem 2rem;
    }
    .ref-card {
      width: 340px;
    }
    .carousel-hint {
      display: none;
    }
  }

  @media (min-width: 1280px) {
    .carousel {
      max-width: 1120px;
      margin: 0 auto;
      scroll-padding-left: 1.5rem;
    }
  }
</style>
